# 应用
APP_NAME=AgentRadar
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173

# 本地直接运行默认使用 SQLite；Docker Compose 默认使用下面的 PostgreSQL 参数
DATABASE_URL=sqlite:///./agentradar.db
POSTGRES_DB=agentradar
POSTGRES_USER=agentradar
POSTGRES_PASSWORD=change-me-in-production
COMPOSE_DATABASE_URL=postgresql+psycopg://agentradar:change-me-in-production@postgres:5432/agentradar

# 容器镜像，网络受限时可替换为可信镜像代理的完整地址
PYTHON_IMAGE=python:3.11-slim
NODE_IMAGE=node:22-alpine
NGINX_IMAGE=nginx:1.27-alpine
POSTGRES_IMAGE=postgres:16-alpine

# 外部服务，密钥只允许通过环境变量传入
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
GITHUB_TIMEOUT_SECONDS=15
GITHUB_MAX_RETRIES=2
GITHUB_CACHE_TTL_SECONDS=300
TRENDING_SCHEDULER_ENABLED=false
TRENDING_COLLECTION_INTERVAL_HOURS=6
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1

# 前端
VITE_API_BASE_URL=http://localhost:8000/api/v1
